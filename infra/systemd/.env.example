# ErisLITE Agent — environment variables
# Copy to /opt/erislite/.env and fill in values before starting the service.

# Required — URL of your Basalt Controller
BASALT_CONTROLLER_URL=http://<controller-ip>

# Required — must match BASALT_AGENT_KEY in the controller's .env
BASALT_AGENT_KEY=69a8788b100c8ce0f4130ba1e6adcf43b57ddcd4351f3285afc1ddbb8e5aa1f4

# Optional — defaults to erislite-<hostname> if not set
# BASALT_AGENT_ID=erislite-myhost

# Optional — heartbeat and poll intervals in seconds
# BASALT_HEARTBEAT_INTERVAL=30
# BASALT_TASK_POLL_INTERVAL=10

# Optional — set to 1 for verbose agent output
# BASALT_DEBUG=0